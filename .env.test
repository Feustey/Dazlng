# Variables d'environnement pour les tests

# URL de base pour les tests
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=mock-key-for-testing

# Next Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=test-secret-for-testing

# Alby
NEXT_PUBLIC_ALBY_CLIENT_ID=test-client-id
NEXT_PUBLIC_ALBY_CLIENT_SECRET=test-client-secret
NEXT_PUBLIC_ALBY_REDIRECT_URI=http://localhost:3000/api/auth/callback/alby

# Mode test
NODE_ENV=test
