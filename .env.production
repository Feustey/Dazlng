

# Configuration de l'authentification
NEXTAUTH_URL=https://dazlng.com
NEXTAUTH_SECRET=production_secret_key
JWT_SECRET=production_jwt_secret

# Configuration de l'API Lightning
LIGHTNING_API_URL=https://api.dazlng.com
LIGHTNING_API_KEY=production_lightning_api_key

# Configuration des services externes
NEXT_PUBLIC_API_URL=https://api.dazlng.com

# Configuration MCP
MCP_API_URL=https://mcp.dazlng.com
MCP_API_KEY=production_mcp_api_key
MCP_API_SECRET=production_mcp_api_secret

MCP_NETWORK=mainnet
NODE_PUBKEY=production_node_pubkey

# Alby API Keys
NEXT_PUBLIC_ALBY_PUBLIC_KEY=production_alby_public_key
ALBY_SECRET=production_alby_secret
ALBY_RELAY_URL=wss://relay.getalby.com/v1
ALBY_LUD16=feustey@getalby.com
ALBY_WEBHOOK_SECRET=production_webhook_secret

# Configuration des webhooks
NEXT_PUBLIC_WEBHOOK_URL=https://webhooks.dazlng.com

# Configuration de l'IA
OPENAI_API_KEY=production_openai_api_key

# Configuration Resend
RESEND_API_KEY=production_resend_api_key


# Environnement
NODE_ENV=production

# New MCP API URL
NEXT_PUBLIC_MCP_API_URL=https://mcp.dazlng.com
