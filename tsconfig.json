{
  "extends": "./app/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@app/*": ["app/*"],
      "@/*": ["app/*"],
      "@components/*": ["app/components/*"],
      "@services/*": ["app/services/*"],
      "@lib/*": ["app/lib/*"],
      "@utils/*": ["app/utils/*"],
      "@ui/*": ["app/components/ui/*"],
      "@hooks/*": ["app/hooks/*"]
    },
    "typeRoots": ["node_modules/@types", "app/node_modules/@types"],
    "types": ["@testing-library/jest-dom", "node", "react", "react-dom"]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next", "archive"]
}
